PORT=5501
ADMIN_API_KEY=change-this-admin-key
ADMIN_AUTH_SECRET=change-this-auth-secret
ADMIN_USERS_JSON=[{"username":"owner","password":"owner-pass-change-me","role":"owner"},{"username":"manager","password":"manager-pass-change-me","role":"manager"},{"username":"staff","password":"staff-pass-change-me","role":"staff"}]
PUBLIC_BASE_URL=http://localhost:5501
DB_FILE=spiceroot.db

# Stripe (required for real payment checkout)
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Razorpay (primary online gateway for India)
RAZORPAY_KEY_ID=rzp_test_replace_me
RAZORPAY_KEY_SECRET=replace_me
RAZORPAY_WEBHOOK_SECRET=whsec_replace_me

# SMTP (optional but recommended for contact emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
CONTACT_RECEIVER_EMAIL=owner@example.com

# UPI (free checkout fallback without payment gateway)
UPI_VPA=yourupiid@okhdfcbank
